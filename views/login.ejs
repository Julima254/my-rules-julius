<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — My Life Tracker</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="login-wrapper">
    <div class="login-card">
      <h1>🧭 My Life Tracker</h1>
      <p class="subtitle">Enter password to continue</p>

      <% if (error) { %>
        <p class="tag failed" style="display:block; text-align:center; margin-bottom:12px;"><%= error %></p>
      <% } %>

      <form action="/login" method="POST">
        <input type="password" name="password" placeholder="Password" required autofocus>
        <button type="submit" class="btn" style="width:100%; margin-top:10px;">Log In</button>
      </form>
    </div>
  </div>
</body>
</html>